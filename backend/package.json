{
  "name": "readerx-backend",
  "version": "2.0.0",
  "description": "Express.js backend for ReaderX — converts PDF/DOCX/MOBI to structured HTML/Markdown",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "testMatch": [
      "<rootDir>/*.test.js"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.0"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
